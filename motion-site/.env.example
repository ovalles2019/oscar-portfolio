# Weekly digest subscribe

# Required for Resend path
RESEND_API_KEY=re_xxxxxxxx

# Optional but recommended: Segment (or legacy Audience) ID
# so contacts are grouped for "Weekly AI Digest" broadcasts
RESEND_SEGMENT_ID=
# Alias still supported:
# RESEND_AUDIENCE_ID=

# Optional fallback: n8n webhook
# SUBSCRIBE_WEBHOOK_URL=https://oscarvalles.app.n8n.cloud/webhook/digest-subscribe

# Optional notify-only (needs verified domain / onboarding sender):
# RESEND_FROM=Digest <onboarding@resend.dev>
# SUBSCRIBE_NOTIFY_TO=you@email.com
